    def _do_migrate(self, dlg):
        # Step 1: pick which VMs to migrate
        vms = get_vms(self.vms_dir)
        if not vms:
            self._warn("No VMs", "There are no VMs in the current location.")
            return

        pick = Gtk.Dialog(title="Select VMs to migrate", parent=self, flags=0)
        pick.set_default_size(440, 480)
        pick.add_buttons("Cancel", Gtk.ResponseType.CANCEL,
                         "Next", Gtk.ResponseType.OK)
        pb = pick.get_content_area()
        pb.set_spacing(8)
        pb.set_margin_top(14); pb.set_margin_bottom(14)
        pb.set_margin_start(14); pb.set_margin_end(14)

        info = Gtk.Label()
        info.set_markup('<span size="small" color="gray">Tick the VMs you want to copy to the new location.</span>')
        info.set_halign(Gtk.Align.START)
        pb.pack_start(info, False, False, 0)

        # Select all / none
        sel_box = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=6)
        all_btn  = Gtk.Button(label="Select all")
        none_btn = Gtk.Button(label="Select none")
        sel_box.pack_start(all_btn, False, False, 0)
        sel_box.pack_start(none_btn, False, False, 0)
        pb.pack_start(sel_box, False, False, 0)

        scroll = Gtk.ScrolledWindow()
        scroll.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC)
        list_box = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=2)
        scroll.add(list_box)
        pb.pack_start(scroll, True, True, 0)

        checks = []
        for vm in vms:
            running_tag = "  [running]" if vm["_running"] else ""
            cb = Gtk.CheckButton(label=f"{vm['_pretty']}  ({vm['_size']}){running_tag}")
            cb._vm = vm
            cb.set_sensitive(not vm["_running"])
            cb.set_tooltip_text("Stop the VM before migrating" if vm["_running"]
                                else f"{vm['_name']}")
            list_box.pack_start(cb, False, False, 0)
            checks.append(cb)

        all_btn.connect("clicked",
            lambda b: [c.set_active(True) for c in checks if c.get_sensitive()])
        none_btn.connect("clicked",
            lambda b: [c.set_active(False) for c in checks])

        pick.show_all()
        r = pick.run()
        selected = [c._vm for c in checks if c.get_active() and c.get_sensitive()]
        pick.destroy()

        if r != Gtk.ResponseType.OK or not selected:
            return

        # Step 2: pick destination
        dest = self._pick_dir("Select destination for migration", str(Path.home()))
        if not dest:
            return
        newdir = str(Path(dest) / "emu")
        if newdir == self.vms_dir:
            self._warn("Same location", "Destination is the same as current.")
            return

        names = "\n  • ".join(v["_pretty"] for v in selected)
        if not self._confirm(
            "Start migration?",
            f"Copy {len(selected)} VM(s) to:\n{newdir}\n\n  • {names}\n\n"
            f"Originals will remain unless you confirm removal afterwards."
        ):
            return

        Path(newdir).mkdir(parents=True, exist_ok=True)

        # Build rsync arg list: each VM dir + its .conf file
        rsync_cmd = ["rsync", "-a", "--info=progress2"]
        for vm in selected:
            vm_dir = str(Path(self.vms_dir) / vm["_name"])
            if Path(vm_dir).exists():
                rsync_cmd.append(vm_dir)
            rsync_cmd.append(vm["_conf"])
        rsync_cmd.append(f"{newdir}/")

        def _migration_done(ok):
            if not ok:
                self._warn("Migration failed", "rsync returned an error.")
                return
            if self._confirm_danger(
                "Remove original files?",
                f"Migration succeeded.\n\n"
                f"Do you want to PERMANENTLY DELETE the {len(selected)} "
                f"migrated VM(s) from the original location?\n\n"
                f"{self.vms_dir}\n\n"
                f"This cannot be undone. The copies in the new location will remain."
            ):
                for vm in selected:
                    vm_dir = Path(self.vms_dir) / vm["_name"]
                    if vm_dir.exists():
                        shutil.rmtree(str(vm_dir))
                    if Path(vm["_conf"]).exists():
                        Path(vm["_conf"]).unlink()
            self._refresh()
            self._refresh_loc_list(dlg)

        self._run_with_progress(
            f"Migrating {len(selected)} VM(s)",
            rsync_cmd,
            on_done=_migration_done
        )

    def _do_add_loc(self, dlg):
        loc = self._pick_dir("Select directory to add to switch list", str(Path.home()))
        if not loc:
            return
        conf = read_conf()
        for i in range(1, 6):
            if not conf.get(f"vms_dir_{i}"):
                setconf(f"vms_dir_{i}", loc)
                self._refresh_loc_list(dlg)
                return
        self._warn("List full", "Maximum 5 saved locations. Remove one first.")

