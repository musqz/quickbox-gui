    def _copy_command_to_clipboard(self, cmd):
        """Copy a command to clipboard."""
        try:
            proc = subprocess.Popen(["xclip", "-selection", "clipboard"], 
                                    stdin=subprocess.PIPE)
            proc.communicate(cmd.encode())
            notify("Command", f"Copied: {cmd}", "low")
        except Exception:
            self._warn("Copy Error", f"Could not copy to clipboard:\n\n{cmd}")

    def _refresh_ssh_menu(self):
        """Rebuild SSH menu with all running VMs that have SSH configured."""
        # Clear existing menu
        for item in self._ssh_menu.get_children():
            self._ssh_menu.remove(item)
        
        # Get all running VMs with SSH configured
        ssh_vms = []
        for vm in self.vms:
            if vm["_running"]:
                self._ensure_ssh_config(vm)
                user = vm.get("ssh_user", "root")
                port = vm.get("ssh_port", "2222")
                ssh_vms.append((vm["_pretty"], user, port, vm))
        
        if not ssh_vms:
            # No running VMs - show placeholder
            item = Gtk.MenuItem(label="No VMs running")
            item.set_sensitive(False)
            self._ssh_menu.append(item)
        else:
            # Add menu items for each running VM
            for pretty_name, user, port, vm in sorted(ssh_vms):
                ssh_cmd = f"ssh -p {port} {user}@localhost"
                label = f"{pretty_name} ({user}@:{port})"
                item = Gtk.MenuItem(label=label)
                item.connect("activate", lambda i, v=vm: self._copy_ssh_for_vm(v))
                self._ssh_menu.append(item)
        
        self._ssh_menu.show_all()



