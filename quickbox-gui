            ("─" * 40, None),  # Separator
            ("Pull single file", "scp -P 2222 root@localhost:/path/to/file /local/path/"),
            ("Push single file", "scp -P 2222 /local/file root@localhost:/remote/path/"),
            ("─" * 40, None),
            ("Pull directory", "scp -P 2222 -r root@localhost:/remote/dir /local/path/"),
            ("Push directory", "scp -P 2222 -r /local/dir root@localhost:/remote/path/"),
            ("─" * 40, None),
            ("Run command", "ssh -p 2222 root@localhost 'ls /home/'"),
        ]
        
        for label, cmd in commands:
            if cmd is None:
                # Separator
