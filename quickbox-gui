    def _clone_vm(self, vm):
        import datetime
        date_str  = datetime.datetime.now().strftime("%Y%m%d")
        suggested = f"{vm['_name']}-{date_str}"

        dlg = Gtk.Dialog(title="Clone VM", parent=self, flags=0)
        dlg.add_buttons("Cancel", Gtk.ResponseType.CANCEL, "Clone", Gtk.ResponseType.OK)
        box = dlg.get_content_area()
        box.set_spacing(8)
        box.set_margin_top(16); box.set_margin_bottom(16)
        box.set_margin_start(16); box.set_margin_end(16)
        box.pack_start(Gtk.Label(label=f"Clone '{vm['_pretty']}' as:"), False, False, 0)
        entry = Gtk.Entry()
        entry.set_text(suggested)
        entry.set_tooltip_text("Name for the cloned VM — date suffix helps track when it was made")
        box.pack_start(entry, False, False, 0)
        hint = Gtk.Label()
        hint.set_markup('<span size="small" color="gray">The clone will appear in the VM list as a separate VM.</span>')
        hint.set_halign(Gtk.Align.START)
        box.pack_start(hint, False, False, 0)
        dlg.show_all()
        r = dlg.run()
        name = entry.get_text().strip()
        dlg.destroy()

        if r != Gtk.ResponseType.OK or not name:
            return

        dest_name = name.replace(" ", "-").lower()
        dest_dir  = Path(self.vms_dir) / dest_name
        dest_conf = Path(self.vms_dir) / f"{dest_name}.conf"
        src_dir   = Path(self.vms_dir) / vm["_name"]
        src_conf  = Path(vm["_conf"])

        if dest_dir.exists() or dest_conf.exists():
            self._warn("Already exists", f"VM '{dest_name}' already exists.")
            return

        try:
            src_vm = read_vm_conf(str(src_conf))
            skip_keys = {"vm_ram", "vm_cpu", "ssh_port"}

            out = ["#!/usr/bin/quickemu --vm"]
            for k, v in src_vm.items():
                if k in skip_keys:
                    continue
                if k == "pretty":
                    out.append(f'pretty="{name}"')
                elif k == "disk_img" and v and vm["_name"] in v:
                    out.append(f'{k}="{v.replace(vm["_name"], dest_name)}"')
                elif v:
                    out.append(f'{k}="{v}"')
                else:
                    out.append(f'{k}=')
            if "pretty" not in src_vm:
                out.append(f'pretty="{name}"')
            dest_conf.write_text("\n".join(out) + "\n")
            dest_conf.chmod(0o755)
        except Exception as e:
            self._warn("Clone failed", f"Could not write conf: {e}")
            return

        # refresh immediately so VM appears in list
        self._refresh()
        self._select_vm_by_name(dest_name)

        # write a flag file so launch is blocked while copying
        flag = Path(self.vms_dir) / f".{dest_name}.copying"
        flag.touch()

        # copy directory in background (may take a while for large disks)
        def _copy_dir():
            try:
                shutil.copytree(str(src_dir), str(dest_dir))
                flag.unlink(missing_ok=True)
                notify("quickbox-gui", f"Clone complete: '{name}' — ready to use", "low")
                GLib.idle_add(self._refresh)
                GLib.timeout_add(200, lambda: self._select_vm_by_name(dest_name) or False)
            except Exception as e:
                flag.unlink(missing_ok=True)
                GLib.idle_add(self._warn, "Clone failed", f"Directory copy failed: {str(e)}")
                GLib.idle_add(dest_conf.unlink)

        threading.Thread(target=_copy_dir, daemon=True).start()

