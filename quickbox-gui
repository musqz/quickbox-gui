    def _refresh(self):
        for row in self.listbox.get_children():
            self.listbox.remove(row)
        self.vms = get_vms(self.vms_dir)
        for vm in self.vms:
            self.listbox.add(VMRow(vm))
        self.listbox.show_all()
        n = len(self.vms)
        self._status.set_markup(
            f'<span size="small">{self.vms_dir}  •  {n} VM{"s" if n != 1 else ""}</span>')
        self._headerbar.set_subtitle(self.vms_dir)
        # re-select
        if self.current_vm:
            name = self.current_vm["_name"]
            for row in self.listbox.get_children():
                if hasattr(row, "vm") and row.vm["_name"] == name:
                    self.listbox.select_row(row)
                    self.current_vm = row.vm
                    break
        self._refresh_ssh_menu()
        return False  # stop GLib.timeout_add

