        dl_btn     = Gtk.Button(label="Download")
        dl_btn.get_style_context().add_class("launch-btn")
        btn_box.pack_end(dl_btn, False, False, 0)
        btn_box.pack_end(cancel_btn, False, False, 0)
        box.pack_start(btn_box, False, False, 0)

        dlg.show_all()

        # State
        self._dl_process  = None
        self._dl_cancelled = False
        self._dl_watching  = False

        def _find_growing_file():
            """Find the newest/largest file being written in vms_dir."""
            try:
                files = []
                for f in Path(self.vms_dir).iterdir():
                    if f.is_file() and f.suffix.lower() in (
                            ".iso", ".img", ".qcow2", ".gz", ".xz", ".zip",
                            ".part", ".tmp", ".download"):
                        files.append((f.stat().st_mtime, f))
                if files:
                    return sorted(files)[-1][1]
            except Exception:
                pass
            return None

        def _watch_progress():
            """Poll the growing download file every second, update progress bar."""
            import math, time
            elapsed = 0
            last_size = 0
            stall_count = 0
            target_file = None

            while self._dl_watching and not self._dl_cancelled:
                time.sleep(1)
                if not self._dl_watching or self._dl_cancelled:
                    break
                elapsed += 1

                # try to find the file being downloaded
                if target_file is None or not target_file.exists():
                    target_file = _find_growing_file()

                if target_file and target_file.exists():
                    try:
                        size = target_file.stat().st_size
                        mb = size / (1024 * 1024)

                        if size > last_size:
                            stall_count = 0
                            # logarithmic curve: grows fast then slows, never hits 1.0
                            # reaches ~0.5 at 200MB, ~0.7 at 1GB, ~0.9 at 8GB
                            fraction = math.log1p(mb) / (math.log1p(mb) + 8)
                            fraction = min(fraction, 0.95)
                            speed = (size - last_size) / (1024 * 1024)
                            GLib.idle_add(progress.set_fraction, fraction)
                            GLib.idle_add(progress.set_text,
                                f"Downloading… {mb:.0f} MB  ({speed:.1f} MB/s)")
                            last_size = size
                        else:
                            stall_count += 1
                            if stall_count > 5:
                                # file not growing — verifying/extracting phase
                                GLib.idle_add(progress.set_text, "Verifying…")
                    except Exception:
                        pass
                else:
                    # no file found yet — slow logarithmic pulse based on time
                    fraction = math.log1p(elapsed / 10) / (math.log1p(elapsed / 10) + 6)
                    fraction = min(fraction, 0.4)
                    GLib.idle_add(progress.set_fraction, fraction)
                    GLib.idle_add(progress.set_text, f"Connecting… ({elapsed}s)")

        def _run_download():
            cmd = cmd_entry.get_text().strip().split()
            GLib.idle_add(progress.set_text, f"Starting download…")
            GLib.idle_add(dl_btn.set_sensitive, False)
            GLib.idle_add(ver_combo.set_sensitive, False)
            GLib.idle_add(cmd_entry.set_editable, False)

            import subprocess as sp
            self._dl_watching = True
            watcher = threading.Thread(target=_watch_progress, daemon=True)
            watcher.start()

            try:
                self._dl_process = sp.Popen(
                    cmd,
                    stdout=sp.DEVNULL, stderr=sp.DEVNULL,
                    cwd=self.vms_dir
                )
                self._dl_process.wait()
                rc = self._dl_process.returncode
            except Exception:
                rc = 1

            self._dl_watching = False
            import time as _time
            _time.sleep(1.2)  # wait for watcher thread to finish its last iteration

            if self._dl_cancelled:
                GLib.idle_add(progress.set_text, "Cancelled")
                GLib.idle_add(progress.set_fraction, 0)
            elif rc == 0:
                GLib.idle_add(progress.set_fraction, 1.0)
                GLib.idle_add(progress.set_text, "Download complete!")
                GLib.idle_add(dl_btn.set_label, "Done — Close")
                GLib.idle_add(dl_btn.set_sensitive, True)
                GLib.idle_add(self._refresh)
            else:
                GLib.idle_add(progress.set_text, "Download failed.")
                GLib.idle_add(dl_btn.set_label, "Close")
                GLib.idle_add(dl_btn.set_sensitive, True)

        def _on_download(btn):
            if btn.get_label() in ("Done — Close", "Close"):
                dlg.destroy()
                return
            threading.Thread(target=_run_download, daemon=True).start()

        def _on_cancel(btn):
            if self._dl_process and self._dl_process.poll() is None:
                self._dl_cancelled = True
                self._dl_process.terminate()
            dlg.destroy()

        dl_btn.connect("clicked", _on_download)
        cancel_btn.connect("clicked", _on_cancel)
        dlg.connect("destroy", lambda d: _on_cancel(cancel_btn))

        dlg.run()


