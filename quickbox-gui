    def _run_with_progress(self, title, cmd_list, cwd=None, on_done=None):
        """Run a command in a background thread with a GUI progress dialog."""
        dlg = Gtk.Dialog(title=title, parent=self, flags=0)
        dlg.set_default_size(460, 160)
        dlg.set_deletable(False)
        box = dlg.get_content_area()
        box.set_margin_top(16); box.set_margin_bottom(16)
        box.set_margin_start(16); box.set_margin_end(16)
        box.set_spacing(10)

        status_lbl = Gtk.Label(label="Please wait…")
        status_lbl.set_halign(Gtk.Align.START)
        box.pack_start(status_lbl, False, False, 0)

        progress = Gtk.ProgressBar()
        progress.set_show_text(False)
        box.pack_start(progress, False, False, 0)

        note = Gtk.Label()
        note.set_markup('<span size="small" color="gray">This may take a while depending on size.</span>')
        note.set_halign(Gtk.Align.START)
        box.pack_start(note, False, False, 0)

        dlg.show_all()

        def _pulse():
            progress.pulse()
            return self._proc_running

        self._proc_running = True
        GLib.timeout_add(150, _pulse)

        def _run():
            try:
                proc = subprocess.run(
                    cmd_list, cwd=cwd,
                    capture_output=True, text=True
                )
                rc = proc.returncode
            except Exception as e:
                rc = 1

            self._proc_running = False

            if rc == 0:
                GLib.idle_add(progress.set_fraction, 1.0)
                GLib.idle_add(status_lbl.set_text, "Done!")
                GLib.idle_add(note.set_markup,
                    '<span size="small" color="gray">Completed successfully.</span>')
            else:
                GLib.idle_add(status_lbl.set_text, "Failed.")
                GLib.idle_add(note.set_markup,
                    '<span size="small" color="red">Something went wrong.</span>')

            def _finish():
                dlg.destroy()
                if on_done:
                    on_done(rc == 0)
            GLib.timeout_add(1200, _finish)

        threading.Thread(target=_run, daemon=True).start()
        dlg.run()

    def _pick_dir(self, title, start):
        fc = Gtk.FileChooserDialog(title=title, parent=self,
                                   action=Gtk.FileChooserAction.SELECT_FOLDER)
        fc.add_buttons("Cancel", Gtk.ResponseType.CANCEL, "Select", Gtk.ResponseType.OK)
        fc.set_current_folder(start)
        r = fc.run()
        path = fc.get_filename() if r == Gtk.ResponseType.OK else None
        fc.destroy()
        return path

    def _confirm(self, title, body):
        dlg = Gtk.MessageDialog(parent=self, flags=0,
                                message_type=Gtk.MessageType.QUESTION,
                                buttons=Gtk.ButtonsType.YES_NO,
                                text=title)
        dlg.format_secondary_text(body)
        r = dlg.run()
        dlg.destroy()
        return r == Gtk.ResponseType.YES

    def _confirm_danger(self, title, body):
            """Confirmation dialog for destructive actions.
            
            Defaults to NO (green/safe). The YES button is styled red as a
            deliberate visual warning to prevent accidental deletes.
            """
            dlg = Gtk.MessageDialog(parent=self, flags=0,
                                    message_type=Gtk.MessageType.WARNING,
                                    buttons=Gtk.ButtonsType.NONE,
                                    text=title)
            dlg.format_secondary_text(body)

            # Green "No, keep files" — safe default
            no_btn = dlg.add_button("No, keep files", Gtk.ResponseType.NO)
            no_ctx = no_btn.get_style_context()
            no_ctx.add_class("suggested-action")  # GTK green accent

            # Red "Yes, delete" — destructive
            yes_btn = dlg.add_button("Yes, delete originals", Gtk.ResponseType.YES)
            yes_ctx = yes_btn.get_style_context()
            yes_ctx.add_class("destructive-action")  # GTK red accent

            # Make NO the default (Enter key = safe choice)
            dlg.set_default_response(Gtk.ResponseType.NO)

            r = dlg.run()
            dlg.destroy()
            return r == Gtk.ResponseType.YES

    def _warn(self, title, body):
        dlg = Gtk.MessageDialog(parent=self, flags=0,
                                message_type=Gtk.MessageType.WARNING,
                                buttons=Gtk.ButtonsType.OK,
                                text=title)
        dlg.format_secondary_text(body)
        dlg.run()
        dlg.destroy()


