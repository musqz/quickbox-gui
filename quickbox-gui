    def _parse_quickinst(self):
        """Parse distro list from ~/.config/quickbox/quickinst.csv."""
        clean_csv = Path.home() / ".config/quickbox/quickinst.csv"
        distros = []
        if not clean_csv.exists():
            return distros
        for line in clean_csv.read_text().splitlines():
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            parts = line.split(",", 1)
            if len(parts) == 2:
                name = parts[0].strip()
                cmd  = parts[1].strip()
                if name and cmd:
                    distros.append((name, cmd))
        return sorted(distros, key=lambda x: x[0].lower())

    def _get_distro_versions(self, distros, distro_name):
        """Get all available versions/editions for a distro name (first word match)."""
        # Extract base distro from display name — e.g. "Ubuntu 24.04 LTS" -> "ubuntu"
        first_word = distro_name.split()[0].lower()
        versions = []
        for name, cmd in distros:
            parts = cmd.split()  # quickget distro release edition
            if len(parts) >= 2 and parts[1].lower() == first_word:
                # version label = everything after distro name in display
                label = name
                versions.append((label, cmd))
        return versions

